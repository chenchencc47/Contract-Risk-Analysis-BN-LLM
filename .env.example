# =============================================================================
# ContractLens — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── LLM Model Configuration ───────────────────────────────────────────────
# LLM₁ (Free Review) uses: OPENAI_API_KEY, OPENAI_BASE_URL, OPENAI_MODEL
# LLM₂ (Report Generation) uses: DEEPSEEK_API_KEY, DEEPSEEK_BASE_URL, DEEPSEEK_MODEL
# Both typically point to the same DeepSeek instance.

# Required: DeepSeek API key (get one at https://platform.deepseek.com)
OPENAI_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# API base URL (DeepSeek default; override if using a proxy or self-hosted)
OPENAI_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model name (deepseek-chat for general, deepseek-v4-flash for fast)
OPENAI_MODEL=deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# ── MySQL Database ─────────────────────────────────────────────────────────
# Required for report history, feedback, and redlines persistence.
# Docker Compose users: these are auto-configured, no changes needed.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=contract_risk

# ── Demo Mode (optional) ───────────────────────────────────────────────────
# Set to true to skip API key and MySQL checks, and serve pre-computed results.
# Useful for: first-time evaluation, CI, offline demos.
#   DEMO_MODE=false
