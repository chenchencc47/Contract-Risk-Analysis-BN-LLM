# =============================================================================
# ContractLens — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── LLM Model Configuration ───────────────────────────────────────────────
# ContractLens 使用 OpenAI 兼容 API 协议，支持任意兼容服务商
# （openai、deepseek、zhipu、moonshot、本地 vllm 等均可）
#
# LLM₁ (Free Review) 使用: OPENAI_API_KEY, OPENAI_BASE_URL, OPENAI_MODEL
# LLM₂ (Report Generation) 使用: DEEPSEEK_API_KEY, DEEPSEEK_BASE_URL, DEEPSEEK_MODEL
# 两者可指向同一服务商，也可分别配置不同模型

# Required: API key（从你的服务商获取）
OPENAI_API_KEY=sk-your-api-key
DEEPSEEK_API_KEY=sk-your-api-key

# API base URL（根据服务商修改）
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.openai.com/v1

# Model name
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=gpt-4o

# ── MySQL Database ─────────────────────────────────────────────────────────
# Required for report history, feedback, and redlines persistence.
# Docker Compose users: these are auto-configured, no changes needed.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=contract_risk

# ── Demo Mode (optional) ───────────────────────────────────────────────────
# Set to true to skip API key and MySQL checks, and serve pre-computed results.
# Useful for: first-time evaluation, CI, offline demos.
#   DEMO_MODE=false
