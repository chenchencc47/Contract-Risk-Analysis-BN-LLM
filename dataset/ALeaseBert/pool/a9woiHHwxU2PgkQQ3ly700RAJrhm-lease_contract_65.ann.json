a national statutory holiday, it will be accordingly postponed to the first working day after the deadline. A late fee at 0.05% of the payable rent shall be charged upon Party B for each day after the deadline."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p52","offsets":[{"start":0,"text":"7."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p52","offsets":[{"start":2,"text":"Lease deposit and other expenses"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p53","offsets":[{"start":0,"text":"7.1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p53","offsets":[{"start":3,"text":"It is agreed by Party A and Party B that, within 10 days (calendar days) after this Contract takes effect, Party B shall pay to Party A the lease deposit for the lease of the Premises. The lease deposit shall be equal to 3 months’ rent, i.e., Renminbi one million two hundred and two thousand nine hundred and three point eighty-six yuan (RMB1,202,903.86)."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p55","offsets":[{"start":0,"text":"7.2"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p55","offsets":[{"start":3,"text":"During the lease term hereunder, Party B shall bear all the expenses incurred by the Premises for water, electricity, gas, telecommunications, equipment, etc."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"services_charges","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p56","offsets":[{"start":0,"text":"7.3"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p56","offsets":[{"start":3,"text":"Party B shall at its own expense apply to relevant departments for completing formalities for using power, gas, telecommunications, etc., and bear all the relevant expenses incurred for installing such facilities."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"services_charges","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p57","offsets":[{"start":0,"text":"7.4"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p58","offsets":[{"start":0,"text":"8."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p58","offsets":[{"start":2,"text":"Use requirements and maintenance responsibilities for the Premises"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p59","offsets":[{"start":0,"text":"8.1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p59","offsets":[{"start":3,"text":"During the lease term hereunder, if Party B discovers any natural damage to the Premises or any of its accessory facilities, it shall promptly notify the property management company designated by Party A to rep