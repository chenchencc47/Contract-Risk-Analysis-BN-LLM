h installment. Where the final payment date of each installment coincides with a Saturday, Sunday or a public holiday, then the final payment date shall be postponed to the first working day subsequent to the holiday. In case Party B defaults on payment, it must pay an overdue fine equivalent to 0.05% per day of the due and unpaid rental."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p47","offsets":[{"start":0,"text":"7."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p47","offsets":[{"start":3,"text":"Lease Deposit and Other Expenses"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p48","offsets":[{"start":0,"text":"7.1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p48","offsets":[{"start":4,"text":"Both parties agree that, Party A will issue to Party B a receipt in the amount of RMB One Million Eight Hundred Four Thousand Three Hundred Fifty Five Point Seven Eight (RMB 1,804,355.78) 10 days prior to the signature date of this Contract."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_23","part":"s1p49","offsets":[{"start":0,"text":"During the lease term, Party B may not set off the lease deposit against the rental of the Premises. Upon termination or expiration of this Contract, within 10 working days after"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"