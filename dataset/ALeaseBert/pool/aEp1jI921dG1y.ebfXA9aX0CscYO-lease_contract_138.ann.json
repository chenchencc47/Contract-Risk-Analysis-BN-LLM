s":{},"normalizations":{}},{"classId":"e_16","part":"s1p13","offsets":[{"start":0,"text":"Article 1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_3","part":"s1p14","offsets":[{"start":0,"text":"Party A agrees to lease to party B the premises of 205-3F, 202-1F, 202-2F, 202-3F of Nanchan Temple, Zijin Plaza."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_4","part":"s1p16","offsets":[{"start":44,"text":"Usage Commercial"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p17","offsets":[{"start":0,"text":"Article 2"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_25","part":"s1p18","offsets":[{"start":49,"text":"December 01, 2009"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_26","part":"s1p18","offsets":[{"start":70,"text":"December 31, 2013"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_9","part":"s1p18","offsets":[{"start":89,"text":"From December 01, 2009 to December 31, 2010 is free lease period (and renovation period is included in free lease period). The lease fee is 5,000,000 RMB per year starting from January 1, 2011."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_9","part":"s1p19","offsets":[{"start":0,"text":"Party B’s payment method is a payment at the beginning per half a year. Before December 1, 2010, 2,500,000 RMB for the first half year must be paid. Before June 1, 2011, 2,500,000 RMB for the second half year must be paid. Before December 1, 2011, 2,500,000 RMB for the third half year must be paid. The payment continues, and the following half year’s payment must be paid before June 1 or December 1 of each year."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_9","part":"s1p20","offsets":[{"start":0,"text":"Based on the following terms, three-year lease fee is divided into 5,00,000 RMB per year. If party B reach the following terms and the number two agreement of the contract, lease fee becomes 9,700,000 RMB per year."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p24","offsets":[{"start":0,"text":"During lease period, at least 95% of shops must be opened."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"special_stipulations","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p27","offsets":[{"start":0,"text":"Article 3"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p28","offsets":[{"start":0,"text":"Party A guarantees that the above mentioned ownership is clear. During lease period, party A has the right to sell its properties, and party B forgoes the priority purchase right."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"right_of_first_refusal_to_purchase","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_23","part":"s1p28","offsets":[{"start":180,"text":"If a property is sold, the ownership is then transferred to the purchaser, but party B’s rights and benefits stay unchanged."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"change_of_control","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p29","offsets":[{"start":0,"text":"Article 4"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p31","offsets":[{"start":0,"text":"Article 5"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p33","offsets":[{"start":0,"text":"Article 6"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_14","part":"s1p34","offsets":[{"start":0,"text":"During lease period, party B, in accordance with laws, covers water, electricity, gas, management, tax, and other costs associated with equipment usage."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p35","offsets":[{"start":0,"text":"Article 7"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p36","offsets":[{"start":0,"text":"Upon expiration, party B must pay off rent and expense related to operation, and it cannot damage the interior renovation."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"damage","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p37","offsets":[{"start":0,"text":"Article 8"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p38","offsets":[{"start":0,"text":"Lease payment guarantee fee: party B must pay 1,000,000 RMB guarantee fee to party A when signing the contract. The guarantee fee paid at signing is considered a deposit (including renovation repair fee). Party A provides an invoice. If no breach of contract occurs upon expiration, party A will return the deposit without interest. Rent is paid every half a year after free lease period ends. Party B must pay half year rent 30 days before free lease period ends, and it must pay cash or wire transfer to party A 30 days before every half year period begins. Party A provides invoices to party B."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"warrantees_of_the_owner","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p39","offsets":[{"start":0,"text":"Article 9"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p40","offsets":[{"start":0,"text":"Breach of Contract: If either party breaches the contract or violates legal regulations, party B has the right to cancel the contract in advance. The party who breaches the contract must pay a penalty fee equal to 50% of the sum of remaining unpaid rent. If party A terminates the contract without reasons, party A will pay a penalty fee and indemnify party B’s renovation cost and economic loss (renovation’s depreciation period is 10 years). If cancelling the contract, party B must pay a penalty fee equal to 50% of the sum of remaining unpaid rent. If party B misses rent payment deadline, it also must pay a late fee, in 15 days, calculated one the basis of 0.3%of monthly rent per day. 15 days after the deadline, party A has the right to confiscate its properties and terminate the contract. Party A has the right to find other lease to avoid the economic, civil, and criminal responsibilities, and party B must pay party A a fee equal to 50% of the yearly rent."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"warrantees_of_the_owner","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_23","part":"s1p42","offsets":[{"start":0,"text":"If utility payment deadline is missed, a late fee equal to 0.3% of monthly total is applied. If the delay is more than 15 days, party A has the right to stop utility supply. Party A needs to keep its account having sufficient balance to pay, if deduction fails, suspension of utility supply will occur and party B has to bear the responsibilities."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"services_charges","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_23","part":"s1p44","offsets":[{"start":0,"text":"Party A has the right to terminate the contract and party B has to bear the responsibilities if party B illegally operate to the extent that affects the public image of Zijin plaza."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"warrantees_of_the_owner","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p45","offsets":[{"start":0,"text":"Article 10"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p47","offsets":[{"start":0,"text":"Article 11"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p48","offsets":[{"start":0,"text":"Party B must enter and renovate 30 days after signing the contract."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"compalsory_reconstraction","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p49","offsets":[{"start":0,"text":"Article 12"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p51","offsets":[{"start":0,"text":"Article 13"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p53","offsets":[{"start":0,"text":"Article 14"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p55","offsets":[{"start":0,"text":"Article 15"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p57","offsets":[{"start":0,"text":"Article 16"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p59","offsets":[{"start":0,"text":"Article 17"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p61","offsets":[{"start":0,"text":"Article 18"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_6","part":"s1p68","offsets":[{"start":0,"text":"Signing Date: November 18, 2009"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}}],"relations":[]}