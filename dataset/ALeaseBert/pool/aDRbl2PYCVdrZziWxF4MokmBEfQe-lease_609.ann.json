dditions, and improvements. All trade fixtures, equipment, furniture, alterations, additions, and improvements not so removed will conclusively be deemed to have been abandoned by Tenant and may be appropriated, sold, stored, destroyed, or otherwise disposed of by Landlord without notice to Tenant or to any other person and without obligation to account for them. Tenant will pay Landlord all expenses incurred in connection with Landlord’s disposition of such property, including without limitation the cost of repairing any damage to the building or premises caused by removal of the property. Tenant’s obligation to observe and perform this covenant this survive the end of this lease."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"reinstatement_clause","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p177","offsets":[{"start":0,"text":"15."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p177","offsets":[{"start":4,"text":"RIGHT OF FIRST REFUSAL TO PURCHASE THE PREMISES"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p178","offsets":[{"start":0,"text":"a."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p178","offsets":[{"start":3,"text":"Grant Landlord grants Tenant a right of first refusal to purchase the premises pursuant to this section."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"right_of_first_refusal_to_purchase","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p179","offsets":[{"start"