ezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p104","offsets":[{"start":0,"text":"2."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p104","offsets":[{"start":2,"text":"The deposit will be interest-free."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p105","offsets":[{"start":0,"text":"3."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p106","offsets":[{"start":0,"text":"4."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p106","offsets":[{"start":2,"text":"Upon the expiration of this Contract, if Party B returns to Party A the Premises and all the office products and equipment provided by Party A for the Premises and settles all the fees, Party A shall within fifteen (15) working days refund to Party B the deposit in full. If Party B fails to settle any fee, Party A shall have the right to deduct the same amount from the deposit and, if the deposit is insufficient to cover the said fee, Party A shall have the right to claim the difference from Party B. If Party B fails to pay any fee by the specified time, Party A will charge Party B a late fee at the percentage specified in Paragraph 3 of Article 9 hereof."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"reinstatement_clause","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"no