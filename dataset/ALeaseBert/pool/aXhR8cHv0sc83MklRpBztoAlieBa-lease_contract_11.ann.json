y A at the rate of 0.3% of the monthly rent."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p22","offsets":[{"start":0,"text":"4-3"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_9","part":"s1p22","offsets":[{"start":4,"text":"The method of payment of the rent shall be as follows: To be pre-paid quarterly. On execution of this Contract, Party B shall pay Party A the earnest money equal to three times of the monthly rent in the amount of RMB255,990, which shall automatically be converted to rent on expiration of the rental-free period."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_16","part":"s1p23","offsets":[{"start":0,"text":"5."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p23","offsets":[{"start":3,"text":"Deposit and Other Fees"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p24","offsets":[{"start":0,"text":"5-1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p24","offsets":[{"start":4,"text":"Both parties agree that Party B shall pay Party A the Deposit equal to the rent of one month in an amount of RMB85,330 when Party A hands over the Premises."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"guarantee_transferable","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_18","part":"s1p27","offsets":[{"start":0,"text":"5-2"}],"coordinates":[],"confidence":{"state":