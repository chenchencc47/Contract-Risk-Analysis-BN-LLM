 the rent quarterly at or before the first day of each quarter, and if the day is a holiday, Party B shall pay at the last working before the holiday. If Party B fails to pay within seven (7) days after the payment is due, for every single day of delay, it shall pay a penalty to Party A at the rate of 0.05% of the rent payable. If the delay is over 30 days, Party A may solely terminate this Contract. If Party A delays to provide an invoice, Party B may also delay the payment of the rent, management fees and other fees."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p23","offsets":[{"start":436,"text":"Party A may solely terminate this Contract."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"break_option","confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1}}},"normalizations":{}},{"classId":"e_16","part":"s1p24","offsets":[{"start":0,"text":"5."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_15","part":"s1p24","offsets":[{"start":3,"text":"Deposit and Other Fees"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_18","part":"s1p25","offsets":[{"start":0,"text":"5-1"}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{},"normalizations":{}},{"classId":"e_23","part":"s1p25","offsets":[{"start":4,"text":"Both parties agree that Party B shall prepay Party A a Deposit equal to the rent of 2 months in an amount of RMB179,415 (in capital: RMB ONE HUNDRED SEVENTYNINE THOUSAND AND FOUR HUNDRED AND FIFTEEN YUAN) when Party A hands over the Premises."}],"coordinates":[],"confidence":{"state":"pre-added","who":["user:terezalat"],"prob":1},"fields":{"f_24":{"value":"warrantees_of_t