      "node_name": "liability_cap",
      "state_by_status": {
        "missing": "unfavorable",
        "unfavorable": "unfavorable",
        "acceptable": "acceptable"
      }
    },
    "governing_law_risk": {
      "node_name": "governing_law_clause",
