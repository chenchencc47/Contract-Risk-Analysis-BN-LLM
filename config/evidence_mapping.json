    "governing_law_clarity": ["present", "missing"],
    "dispute_resolution_clarity": ["present", "missing"],
    "jurisdiction_fairness": ["balanced", "counterparty_favorable"],
    "termination_clause": ["present", "missing"],
    "liability_cap": ["acceptable", "unfavorable"],
    "confidentiality_nli": ["entailment", "neutral", "contradiction"],
    "governing_law_clause": ["present", "missing"],
    "dispute_resolution_clause": ["present", "missing"]
