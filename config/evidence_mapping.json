  "hypothesis_rules": {
    "Agreement contains a confidentiality restriction.": {
      "node_name": "confidentiality_nli",
      "state_by_status": {
        "contradiction": "contradiction",
        "entailment": "entailment",
        "neutral": "neutral"
      }
    }
  }
